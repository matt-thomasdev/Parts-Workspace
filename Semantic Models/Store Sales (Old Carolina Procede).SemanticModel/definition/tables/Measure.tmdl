	measure 'YOY Total Sale (Parts Table)' =
			
			VAR __ValueCurrentPeriod = [Total Sale (Parts Table)]
			VAR __ValuePreviousPeriod = [PY Total Sale (Parts Table)]
			VAR __Result =
			    IF (
			        NOT ISBLANK ( __ValueCurrentPeriod ) && NOT ISBLANK ( __ValuePreviousPeriod ),
			        __ValueCurrentPeriod - __ValuePreviousPeriod
			    )
			RETURN
			    __Result
