	measure 'Override Amt' = SUMX('Parts_Service Sales','Parts_Service Sales'[AmtPrice]-'Parts_Service Sales'[AmtPriceSuggest])
		lineageTag: 47e3912b-5a11-47ad-a769-ef0c4e049468

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Sale Suggested' =
			
			SUMX('Parts_Service Sales','Parts_Service Sales'[AmtPriceSuggest]*'Parts_Service Sales'[QtyShip])
		lineageTag: 1a34684b-6ea5-4f4d-b2db-7e3a468d3c51

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Override Amt' = [Total Sale (Parts Table)]-[Total Sale Suggested]
		lineageTag: 2cd8c8ee-5751-4996-bb5f-28c95ad6c41c

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Gross Suggested' = [Total Sale Suggested] - [Total Cost (Parts Table)]
		lineageTag: c5468ad7-7716-4b4b-927d-b1070f3a50f1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'GM% Suggested' = [Total Gross Suggested]/[Total Sale Suggested]
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 647c1191-a8f0-4824-9061-0d0a412cb653

	measure 'Count Of Part Number Pr SLS' =
			
			CALCULATE (
			    COUNTROWS (
			        FILTER (
			            'Parts_Service Sales',
			            LEFT ( 'Parts_Service Sales'[Reason], 4 ) IN { "RA10", "XA10", "XA20", "RA20" } &&
			            'Parts_Service Sales'[ItmTyp] IN { 528, 591 }
			        )
			    )
			)
		formatString: 0
		lineageTag: 30d4c1c6-7e45-4132-a63b-b20cacfa1260

	measure Measure
		lineageTag: 59821243-ae5a-45dd-b8ef-f7cd3e2f2002

		annotation 43dbc3e8-3a1c-4b6f-9923-b49ff7d6691c = True

	measure 'Count Of Part Number Sold' =
			
			CALCULATE (
			    COUNTROWS (
			        FILTER (
			            'Parts_Service Sales',
			            'Parts_Service Sales'[ItmTyp] IN { 528, 591 }
			        )
			    )
			)
		formatString: 0
		lineageTag: 07059721-39bf-408a-83f2-0bd36b6c039e

	measure 'Total Shipped From Stock' =
			
			[Count Of Part Number Sold]-[Count Of Part Number Pr SLS]
		formatString: 0
		lineageTag: d2298fc8-4dbc-4433-b345-62292d600345

	measure 'Fill Rate' =
			
			( [Total Shipped From Stock] / [Count Of Part Number Sold] )
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: ff632090-1452-45a0-8836-d85677c7ed60

