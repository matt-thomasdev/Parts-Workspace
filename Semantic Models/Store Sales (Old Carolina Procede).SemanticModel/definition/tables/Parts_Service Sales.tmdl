	column Location =
			
			SWITCH (
			    VALUE('Parts_Service Sales'[BrnId]),  -- Convert text to integer using VALUE function
			    101, "Columbia",
			    102, "Greer",
			    103, "Charelston",
			    104, "Florence",
			    106, "Greenville",
			    107, "Conway",
			    501, "Lease - Columbia",
			    503, "Lease - Charleston",
			    504, "Lease - Florence",
			    506, "Lease - Greenville",
			    "Other"  -- Handle any other cases not explicitly defined
