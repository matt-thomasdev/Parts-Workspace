	column AgeBucket = ```
			
			VAR CurrentDate = TODAY()
			VAR DaysDifference = DATEDIFF('Parts_Service Sales'[DateCreate], CurrentDate, DAY)
			RETURN
			    SWITCH(
			        TRUE(),
			        DaysDifference <= 29, "1-29 days",
			        DaysDifference <= 60, "30-60 days",
			        DaysDifference <= 90, "61-90 days",
			        DaysDifference <= 120, "91-120 days",
			        "Over 120 days"
			    )
			
			```
		lineageTag: 8b21a6a2-abab-44b2-a3c4-a09aa5421fa5
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

