	column 'Margin% Per Part' = ```
			
			VAR Sale = PTTAP[AmtPrice2]
			VAR Margin = PTTAP[AmtPrice2]-PTTAP[AmtCost] -- Assuming this is a column or can be calculated row-wise
			RETURN DIVIDE(Margin, Sale, 0)
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 81ad959c-3841-4b5c-a5db-133b7101a64d
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Margin% Bucket' = ```
			
			SWITCH(
			    TRUE(),
			    [Margin% Per Part] < 0.1, "0-10%",
			    [Margin% Per Part] >= 0.1 && [Margin% Per Part] <= 0.2, "10-20%",
			    [Margin% Per Part] > 0.2 && [Margin% Per Part] <= 0.25, "21-25%",
			    [Margin% Per Part] > 0.25 && [Margin% Per Part] <= 0.3, "26-30%",
			    [Margin% Per Part] > 0.3 && [Margin% Per Part] <= 0.4, "30-40%",
			    [Margin% Per Part] > 0.4 && [Margin% Per Part] <= 0.5, "40-50%",
			    [Margin% Per Part] > 0.5, "50%+",
			    "Other"
			)
			
			```
		lineageTag: 0e89fe21-60bf-4d65-a31c-267c91561d61
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

