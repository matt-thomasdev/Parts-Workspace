	column PriceCheckStatus = ```
			
			IF (
			    (PTTAP[AmtPrice1] <> 0 && PTTAP[AmtPrice1] <= PTTAP[AmtCost]) ||
			    (PTTAP[AmtPrice2] <> 0 && PTTAP[AmtPrice2] <= PTTAP[AmtCost]) ||
			    (PTTAP[AmtPrice3] <> 0 && PTTAP[AmtPrice3] <= PTTAP[AmtCost]) ||
			    (PTTAP[AmtPrice4] <> 0 && PTTAP[AmtPrice4] <= PTTAP[AmtCost]) ||
			    (PTTAP[AmtPrice5] <> 0 && PTTAP[AmtPrice5] <= PTTAP[AmtCost]) ||
			    (PTTAP[AmtPrice6] <> 0 && PTTAP[AmtPrice6] <= PTTAP[AmtCost]) ||
			    (PTTAP[AmtPrice7] <> 0 && PTTAP[AmtPrice7] <= PTTAP[AmtCost]) ||
			    (PTTAP[AmtPrice8] <> 0 && PTTAP[AmtPrice8] <= PTTAP[AmtCost]),
			    "Check",
			    "Not Good"
			)
			
			```
		lineageTag: 6562b223-5523-4371-b77f-c47d0dcdb14c
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Relationship
		dataType: string
