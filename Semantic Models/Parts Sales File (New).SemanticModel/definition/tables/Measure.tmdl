	measure 'Sales Budget' =
			CALCULATE(
			    [Budget (ABS)],
			    FILTER(
			        ALL(MT_ACMCA[MiniCategory]),
			        MT_ACMCA[MiniCategory] = "01. Sales"
			    ))
		lineageTag: 360bdd6d-94ad-4d4e-9120-4400c3e7c524

