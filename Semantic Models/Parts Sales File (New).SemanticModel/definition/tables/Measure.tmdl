	measure 'PY Total Sale (Parts Table)' =
			
			IF (
			    [_ShowValueForDates],
			    CALCULATE (
			        [Total Sale (Parts Table)],
			        CALCULATETABLE (
			            DATEADD ( 'Date'[Date], -1, YEAR ),
			            'Date'[DateWithTransactions] = TRUE
			        )
			    )
			)
		formatString: #,0.00
		displayFolder: Time intelligence\Growth\Total Sale (Parts Table)
		lineageTag: 34fa46b7-febf-4b1a-af27-15dfd41b9957

		annotation SQLBI_Template = TimeIntelligence

		annotation SQLBI_TimeIntelligence = Standard

		annotation SQLBI_CalendarType = Calendar

	measure 'YOY Total Sale (Parts Table)' =
			
			VAR __ValueCurrentPeriod = [Total Sale (Parts Table)]
			VAR __ValuePreviousPeriod = [PY Total Sale (Parts Table)]
			VAR __Result =
			    IF (
			        NOT ISBLANK ( __ValueCurrentPeriod ) && NOT ISBLANK ( __ValuePreviousPeriod ),
			        __ValueCurrentPeriod - __ValuePreviousPeriod
			    )
			RETURN
			    __Result
		formatString: #,0.00
		displayFolder: Time intelligence\Growth\Total Sale (Parts Table)
		lineageTag: 32327550-141c-4bda-b408-f0e42c1a5cd8

		annotation SQLBI_Template = TimeIntelligence

		annotation SQLBI_TimeIntelligence = Standard

		annotation SQLBI_CalendarType = Calendar

	measure 'PQ Total Sale (Parts Table)' =
			
			IF (
			    [_ShowValueForDates],
			    CALCULATE (
			        [Total Sale (Parts Table)],
			        CALCULATETABLE (
			            DATEADD ( 'Date'[Date], -1, QUARTER ),
			            'Date'[DateWithTransactions] = TRUE
			        )
			    )
			)
		formatString: #,0.00
		displayFolder: Time intelligence\Growth\Total Sale (Parts Table)
		lineageTag: 4ec4d767-7693-45a9-bdab-1b89f2737be1

		annotation SQLBI_Template = TimeIntelligence

		annotation SQLBI_TimeIntelligence = Standard

		annotation SQLBI_CalendarType = Calendar

	measure 'QOQ Total Sale (Parts Table)' =
			
			VAR __ValueCurrentPeriod = [Total Sale (Parts Table)]
			VAR __ValuePreviousPeriod = [PQ Total Sale (Parts Table)]
			VAR __Result =
			    IF (
			        ISBLANK ( __ValueCurrentPeriod ) && NOT ISBLANK ( __ValuePreviousPeriod ),
			        0 - __ValuePreviousPeriod,  // Lost customers (negative change)
			        IF (
			            NOT ISBLANK ( __ValueCurrentPeriod ) && ISBLANK ( __ValuePreviousPeriod ),
			            __ValueCurrentPeriod,  // New customers (positive change)
			            IF (
			                NOT ISBLANK ( __ValueCurrentPeriod ) && NOT ISBLANK ( __ValuePreviousPeriod ),
			                __ValueCurrentPeriod - __ValuePreviousPeriod,  // Both periods (difference)
			                BLANK()  // Both blank
			            )
			        )
			    )
			RETURN
			    __Result
		formatString: #,0.00
		displayFolder: Time intelligence\Growth\Total Sale (Parts Table)
		lineageTag: 10decede-b755-45b6-b922-0b655b669fb3

		annotation SQLBI_Template = TimeIntelligence

		annotation SQLBI_TimeIntelligence = Standard

		annotation SQLBI_CalendarType = Calendar

	measure 'QOQ % Total Sale (Parts Table)' = ```
			
