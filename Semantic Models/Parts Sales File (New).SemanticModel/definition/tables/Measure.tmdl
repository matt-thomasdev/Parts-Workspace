	measure 'Total Sale (Front) Rolling 12 Months' =
			
			CALCULATE(
			    SUMX(
			        'Parts_Service Sales',
			        'Parts_Service Sales'[AmtPrice] * 'Parts_Service Sales'[QtyShip]
			    ),
			    'Parts_Service Sales'[Origin] = "Front",
			    DATESINPERIOD(
			        'Parts_Service Sales'[DateInvoice],
			        MAX('Parts_Service Sales'[DateInvoice]),
			        -12,
			        MONTH
			    )
			)
		displayFolder: 02. Parts Table Measures
		lineageTag: 261988eb-ff17-46a8-af5b-9f3b8ee1b7a0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Sold Sales Spark Line' = ```
			
			
			// line and area colour - use %23 instead of # for Firefox compatibility (Measure Derived from Eldersveld Modified by Kolosko)
			VAR CurrentYear = YEAR(TODAY())
			
			VAR Defs = "<defs>
			    <linearGradient id='grad' x1='0' y1='25' x2='0' y2='50' gradientUnits='userSpaceOnUse'>
			        <stop stop-color='white' offset='0' />
			        <stop stop-color='transparent' offset='1' />
			    </linearGradient>
			</defs>"
			
			// Build a table of month start dates and total billed hours for each month in the current year
			VAR FilteredMonths =
			    ADDCOLUMNS(
			        SUMMARIZE(
			            FILTER(ALL('Date'), YEAR('Date'[Date]) = CurrentYear),
			            'Date'[Year], 'Date'[Month], "MonthStart", MIN('Date'[Date])
			        ),
			        "TotalHours", CALCULATE([Total Sale (Parts Table)], DATESBETWEEN('Date'[Date], [MonthStart], EOMONTH([MonthStart], 0)))
			    )
			
			// X axis: min and max of MonthStart
			VAR XMinDate = MINX(FilteredMonths, [MonthStart])
			VAR XMaxDate = MAXX(FilteredMonths, [MonthStart])
			
			// Y axis: min and max of monthly billed hours
			VAR YMinValue = MINX(FilteredMonths, [TotalHours])
			VAR YMaxValue = MAXX(FilteredMonths, [TotalHours])
			
			// Build table of X & Y coordinates and fit to 50 x 150 viewbox
			VAR SparklineTable = ADDCOLUMNS(
			    FilteredMonths,
			        "X", INT(150 * DIVIDE([MonthStart] - XMinDate, XMaxDate - XMinDate)),
			        "Y", INT(50 * DIVIDE([TotalHours] - YMinValue, YMaxValue - YMinValue))
			)
			
			// Concatenate X & Y coordinates to build the sparkline
			VAR Lines = CONCATENATEX(SparklineTable, [X] & "," & 50 - [Y], " ", [MonthStart])
			
			// Add to SVG, and verify Data Category is set to Image URL for this measure
			VAR SVGImageURL = IF(HASONEVALUE('Parts_Service Sales'[Name]),
			    "data:image/svg+xml;utf8," & 
			    "<svg xmlns='http://www.w3.org/2000/svg' x='0px' y='0px' viewBox='0 0 150 50'>" & Defs &
			     "<polyline fill='url(#grad)' fill-opacity='0.3' stroke='white' 
			      stroke-width='3' points=' 0 50 " & Lines & 
			      " 150 150 Z '/></svg>",
			     BLANK())
			
			RETURN SVGImageURL
			
			
			```
		lineageTag: 2b4b3445-52b4-4876-bb2a-06316134a358
		dataCategory: ImageUrl

	measure 'PY Total Sale (Accounting)' =
			
