	measure 'Margin Budget' = ```
			
			VAR Sales =CALCULATE(
			    [Budget (ABS)],
			    FILTER(
			        ALL(MT_ACMCA[MiniCategory]),
			        MT_ACMCA[MiniCategory] = "01. Sales"
			    ))
			VAR Cost = CALCULATE(
			    [Budget (ABS)],
			    FILTER(
			        ALL(MT_ACMCA[MiniCategory]),
			        MT_ACMCA[MiniCategory] = "02. Cost Of Sales"
			    ))
			VAR Result = Sales-Cost
			RETURN
			Result
			
			```
