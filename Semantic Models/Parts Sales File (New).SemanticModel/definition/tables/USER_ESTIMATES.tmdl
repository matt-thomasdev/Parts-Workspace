			    506, "Lease - Greenville",
			    601, "Lease - Miami",
			    602, "Lease - Ft Lauderdale",
			    603, "Lease - West Palm Beach",
			    604, "Lease - Ft Pierce",
			    605, "Lease - Ft Myers",
			    "Other"  -- Handle any other cases not explicitly defined
			)
