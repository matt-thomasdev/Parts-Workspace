			    VALUE(USER_ESTIMATES[BrnId]),  -- Convert text to integer using VALUE function
			    201, "Miami",
			    202, "Fort Lauderdale",
			    203, "West Palm",
			    204, "Fort Pierce",
			    205, "Fort Myers",
			    101, "Columbia",
			    102, "Charelston",
