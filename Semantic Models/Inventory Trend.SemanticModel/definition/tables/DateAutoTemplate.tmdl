	hierarchy Calendar
		isHidden
		lineageTag: 4c5613b6-0485-41f4-ac3d-68199f151048

		level Year
			lineageTag: fa6fbc07-bd6b-4abb-887f-6f4c635ec4e2
			column: Year

		level Month
			lineageTag: 642ddb71-a400-4e58-8092-0bdd954ae095
			column: 'Year Month'

		level Date
			lineageTag: a3b011d2-7cf3-413d-a768-3f0d61c8668b
			column: Date

	partition DateAutoTemplate = calculated
		mode: import
		source = ```
				
				--  
				--     Configuration
				--  
				VAR __FirstDayOfWeek = 1
				----------------------------------------
				VAR __WeekDayCalculationType = IF ( __FirstDayOfWeek = 0, 7, __FirstDayOfWeek ) + 10
				VAR __Calendar = 
				    VAR __FirstYear = YEAR ( MINX ( { MIN ( 'USER_INVENTORYSNAPSHOT'[Date] ), MIN ( 'USER_INVENTORYSNAPSHOT'[DateSale] ), MIN ( 'USER_INVENTORYSNAPSHOT'[DateOrder] ), MIN ( 'MT_INVENTORY'[DateSale] ), MIN ( 'MT_INVENTORY'[DateOrder] ), MIN ( 'MT_INVENTORY'[DateCount] ), MIN ( 'MT_INVENTORY'[DateLevel] ), MIN ( 'MT_INVENTORY'[DateTape] ), MIN ( 'MT_INVENTORY'[DateCreate] ), MIN ( 'MT_INVENTORY'[DateUpdate] ) }, ''[Value] ) )
				    VAR __LastYear =  YEAR ( MAXX ( { MAX ( 'USER_INVENTORYSNAPSHOT'[Date] ), MAX ( 'USER_INVENTORYSNAPSHOT'[DateSale] ), MAX ( 'USER_INVENTORYSNAPSHOT'[DateOrder] ), MAX ( 'MT_INVENTORY'[DateSale] ), MAX ( 'MT_INVENTORY'[DateOrder] ), MAX ( 'MT_INVENTORY'[DateCount] ), MAX ( 'MT_INVENTORY'[DateLevel] ), MAX ( 'MT_INVENTORY'[DateTape] ), MAX ( 'MT_INVENTORY'[DateCreate] ), MAX ( 'MT_INVENTORY'[DateUpdate] ) }, ''[Value] ) )
				    RETURN CALENDAR (
				        DATE ( __FirstYear, 1, 1 ),
				        DATE ( __LastYear, 12, 31 )
				    )
				VAR __Step3 = 
				    GENERATE (
				        __Calendar,
				        VAR __IsStandardLocale = IF ( FORMAT( DATE( 2000, 1, 1 ), "oooo" ) = "oooo", TRUE, FALSE )
				        VAR __MonthFormatString = IF( __IsStandardLocale, "mmm", "ooo" )
				        VAR __DayFormatString = IF( __IsStandardLocale, "ddd", "aaa" )
				        VAR __LastTransactionDate = MAXX ( { MAX ( 'USER_INVENTORYSNAPSHOT'[Date] ), MAX ( 'USER_INVENTORYSNAPSHOT'[DateSale] ), MAX ( 'USER_INVENTORYSNAPSHOT'[DateOrder] ), MAX ( 'MT_INVENTORY'[DateSale] ), MAX ( 'MT_INVENTORY'[DateOrder] ), MAX ( 'MT_INVENTORY'[DateCount] ), MAX ( 'MT_INVENTORY'[DateLevel] ), MAX ( 'MT_INVENTORY'[DateTape] ), MAX ( 'MT_INVENTORY'[DateCreate] ), MAX ( 'MT_INVENTORY'[DateUpdate] ) }, ''[Value] )
				        VAR __Date = [Date]
				        VAR __YearNumber = YEAR ( __Date )
				        VAR __QuarterNumber = QUARTER ( __Date )
				        VAR __YearQuarterNumber = CONVERT ( __YearNumber * 4 + __QuarterNumber - 1, INTEGER )
				        VAR __MonthNumber = MONTH ( __Date )
				        VAR __WeekDayNumber = WEEKDAY ( __Date, __WeekDayCalculationType )
				        VAR __WeekDay = FORMAT ( __Date, __DayFormatString )
				        RETURN ROW ( 
				            "Year", __YearNumber,
				            "Year Quarter Number", __YearQuarterNumber,
				            "Year Quarter", FORMAT ( __QuarterNumber, "\Q0" ) & "-" & FORMAT ( __YearNumber, "0000" ),
				            "Quarter", FORMAT( __QuarterNumber, "\Q0" ),
				            "Year Month", FORMAT ( __Date, __MonthFormatString & " yyyy" ),
				            "Year Month Number", __YearNumber * 12 + __MonthNumber - 1,
				            "Month", FORMAT ( __Date, __MonthFormatString ),
				            "Month Number", __MonthNumber,
				            "Day of Week Number", __WeekDayNumber,
				            "Day of Week", __WeekDay,
				            "DateWithTransactions", __Date <= __LastTransactionDate 
				        )
				    )
				RETURN
				    __Step3
				```

	annotation SQLBI_Template = Dates

	annotation SQLBI_TemplateTable = DateAutoTemplate

	annotation SQLBI_CalendarType = Calendar

