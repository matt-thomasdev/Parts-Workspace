	measure 'Variance Totals' = [Total Amount] - [PM Total Amount]
		lineageTag: 0baadf38-fb13-44e7-b97c-cdbce19ada47

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Variance Totals %' = DIVIDE([Variance Totals], [PM Total Amount])
		lineageTag: e79a037d-5b39-455e-a20f-9332b7c254ed

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Variance Total % Difference' =
			
			var _uparrow = UNICHAR(129129)
			var _downarrow = UNICHAR(129131)
			var _varpercentage = [Variance Totals %]
			var _varnumber = [Variance Totals]
			var _blank = ISBLANK([Total Amount])
			RETURN
			IF(_blank, BLANK(),
			IF(_varnumber > 0,
			    ROUND(_varpercentage,2)*100 & "%" & _uparrow,
			    ROUND(_varpercentage,2)*100 & "%" & _downarrow)
			)
		lineageTag: 2008978f-0c40-4472-b143-479bcd0d1dd6

	measure 'Variance Delivery' = [Total Deliveries] - [PM Total Deliveries]
		formatString: 0
		lineageTag: 028917f7-6256-43c7-8738-4e91f10374db

	measure 'Variance Delivery %' = DIVIDE([Variance Delivery],[PM Total Deliveries])
		lineageTag: b5bc940a-c7d4-4a02-86d1-34fd55b1587b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Variance Delivery Difference' = ```
			
			VAR _uparrow = UNICHAR(129129)
			VAR _downarrow = UNICHAR(129131)
			VAR _varpercentage = [Variance Delivery %]
			VAR _varnumber = [Variance Delivery]
			VAR _blank = ISBLANK([Total Deliveries])
			RETURN
			IF(
			    _blank, 
			    BLANK(),
			    IF(
			        _varnumber > 0,
			        ROUND(_varpercentage, 2) * 100 & "%" & _uparrow,
			        ROUND(_varpercentage, 2) * 100 & "%" & _downarrow
			    )
			)
			
			```
		lineageTag: c76be287-e218-4ae2-b6da-f9c62b843f1c

