	measure 'MATG Average Time Between Deliveries' =
			
			VAR __ValueCurrentPeriod = [MAT Average Time Between Deliveries]
			VAR __ValuePreviousPeriod = [PYMAT Average Time Between Deliveries]
			VAR __Result =
			    IF (
			        NOT ISBLANK ( __ValueCurrentPeriod ) && NOT ISBLANK ( __ValuePreviousPeriod ),
			        __ValueCurrentPeriod - __ValuePreviousPeriod
			    )
			RETURN
			    __Result
