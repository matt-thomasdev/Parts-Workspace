table Measure
	lineageTag: 30a12af4-f5a2-42bb-b118-fb0abb2fa74b

	measure 'Average Time Between Deliveries' = AVERAGE('Elite Extra'[Time Between Delivery])
		lineageTag: 50f673df-1624-48f3-81dd-5904fdbf266c

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Deliveries per Hour' = ```
			
			    CALCULATE(
			        COUNTROWS('Elite Extra'),
			        ALLEXCEPT('Elite Extra', 'Elite Extra'[Delivery Time]),
			        HOUR('Elite Extra'[Delivery Time]) = HOUR(MAX('Elite Extra'[Delivery Time]))
			    )
			
			
			
			```
		formatString: 0
		lineageTag: 6ce0e97c-0e31-4389-a1aa-da48648ba6fc

	measure 'Driver Name Display' = ```
			
			    IF(
			        ISFILTERED('Elite Extra'[Driver Name]),
			        SELECTEDVALUE('Elite Extra'[Driver Name]),
			        BLANK()
			    )
			```
		lineageTag: 381428d7-1b5b-4cfa-8fe2-a37c59dc4cfa

	measure 'MAT Average Time Between Deliveries' =
			
			IF (
			    [_ShowValueForDates],
			    CALCULATE (
			        [Average Time Between Deliveries],
			        DATESINPERIOD (
			            'Date'[Date],
			            MAX ( 'Date'[Date] ),
			            -1,
			            YEAR
			        )
			    )
			)
		lineageTag: 3f239a1b-8fbe-4842-9886-b4a7512f9aa4

		annotation SQLBI_Template = TimeIntelligence

		annotation SQLBI_TimeIntelligence = Standard

		annotation SQLBI_CalendarType = Calendar

